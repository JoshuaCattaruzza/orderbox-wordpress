# Copy to .env and fill in values before running.
# Local dev can omit this file — all variables have sensible defaults.

# Tenant subdomain (e.g. rajmahal → rajmahal.orderbox.me in prod, orderbox.test in local dev)
SUBDOMAIN=demo

# OrderBox API base URL
# Local dev:  http://orderbox_api:3000
# Production: https://orderbox-api-3e2wtmanta-nw.a.run.app
ORDERBOX_API_URL=http://orderbox_api:3000

# MySQL credentials
DB_PASSWORD=wordpress
DB_ROOT_PASSWORD=root

# Path to the mu-plugins directory containing orderbox.php
# Local dev:  ./mu-plugins  (relative to this repo)
# Production: /opt/orderbox-wordpress/mu-plugins  (absolute path on VM)
MU_PLUGINS_PATH=./mu-plugins
